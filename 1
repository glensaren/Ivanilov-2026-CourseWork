    async function submitReview() {
        const email = document.getElementById('review-email').value;
        const text = document.getElementById('review-text').value;
        const rating = parseInt(document.getElementById('review-rating').value);
        const messageEl = document.getElementById('review-message');

        if (!rating) {
            messageEl.className = 'alert alert-danger';
            messageEl.textContent = 'Выберите оценку';
            messageEl.classList.remove('d-none');
            return;
        }

        const response = await fetch(`${API_BASE}/reviews/`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': getCookie('csrftoken')
            },
            credentials: 'include',
            body: JSON.stringify({ email, text, rating })
        });

        if (response.ok) {
            messageEl.className = 'alert alert-success';
            messageEl.textContent = 'Спасибо за отзыв! Он появится после модерации.';
            messageEl.classList.remove('d-none');
            document.getElementById('review-email').value = '';
            document.getElementById('review-text').value = '';
            document.getElementById('review-rating').value = '0';
            document.querySelectorAll('.star-btn').forEach(s => {
                s.className = 'bi bi-star star-btn';
            });
        } else {
            const data = await response.json();
            let errorText = 'Ошибка отправки отзыва.';
            if (data.text) errorText = data.text[0];
            else if (data.rating) errorText = data.rating[0];
            else if (data.email) errorText = data.email[0];
            messageEl.className = 'alert alert-danger';
            messageEl.textContent = errorText;
            messageEl.classList.remove('d-none');
        }
    }

    async function loadAlbums() {
        const container = document.getElementById('albums-container');
        
        {% if not user.is_authenticated %}
        container.innerHTML = document.getElementById('empty-template').innerHTML;
        return;
        {% endif %}

        try {
            const response = await fetch(`${API_BASE}/albums/my/`, {
                credentials: 'include'
            });
            if (!response.ok) throw new Error(`Ошибка ${response.status}`);
            const data = await response.json();
            let albums = Array.isArray(data) ? data : (data.results || []);

            if (albums.length === 0) {
                container.innerHTML = document.getElementById('empty-template').innerHTML;
                return;
            }

            let html = '<div class="row">';
            albums.forEach(album => {
                let coverImage = '';
                if (album.photos && album.photos.length > 0) {
                    const lastPhoto = album.photos.reduce((latest, current) =>
                        new Date(current.added_at) > new Date(latest.added_at) ? current : latest
                    );
                    if (lastPhoto && lastPhoto.photo && lastPhoto.photo.image) {
                        coverImage = `<img src="${lastPhoto.photo.image}"
                                        class="card-img-top"
                                        style="height: 180px; object-fit: cover;"
                                        alt="${lastPhoto.photo.title}">`;
                    }
                }
                html += `
                    <div class="col-md-4 col-lg-3 mb-4">
                        <div class="card album-card h-100" onclick="viewAlbum(${album.id})">
                            ${coverImage || `
                                <div class="card-img-top d-flex align-items-center justify-content-center"
                                    style="height: 180px; background-color: #f8f9fa;">
                                    <i class="bi bi-journal-album" style="font-size: 3rem; color: #6c757d;"></i>
                                </div>
                            `}
                            <div class="card-body">
                                <h5 class="card-title">${album.title || 'Без названия'}</h5>
                                <p class="card-text text-muted small">${album.photo_count || 0} фото</p>
                                <small class="text-muted">
                                    Создан: ${new Date(album.created_at).toLocaleDateString('ru-RU')}
                                </small>
                            </div>
                        </div>
                    </div>`;
            });
            html += '</div>';
            container.innerHTML = html;
        } catch (error) {
            container.innerHTML = `<div class="alert alert-danger">Ошибка загрузки: ${error.message}</div>`;
        }
    }

    async function login(credentials) {
        const response = await fetch(`${API_BASE}/login/`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': getCookie('csrftoken')
            },
            body: JSON.stringify(credentials),
            credentials: 'include'
        });
        const messageEl = document.getElementById('login-message');
        if (response.ok) {
            messageEl.className = 'alert alert-success';
            messageEl.textContent = 'Успешный вход!';
            messageEl.classList.remove('d-none');
            setTimeout(() => window.location.reload(), 1000);
        } else {
            messageEl.className = 'alert alert-danger';
            messageEl.textContent = 'Ошибка входа. Проверьте данные.';
            messageEl.classList.remove('d-none');
        }
    }

    async function register(data) {
        if (data.password !== data.password2) {
            const messageEl = document.getElementById('register-message');
            messageEl.className = 'alert alert-danger';
            messageEl.textContent = 'Пароли не совпадают';
            messageEl.classList.remove('d-none');
            return;
        }
        const response = await fetch(`${API_BASE}/register/`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': getCookie('csrftoken')
            },
            body: JSON.stringify({
                username: data.username,
                email: data.email,
                password: data.password
            })
        });
        const messageEl = document.getElementById('register-message');
        if (response.ok) {
            messageEl.className = 'alert alert-success';
            messageEl.textContent = 'Регистрация успешна! Войдите в систему.';
            messageEl.classList.remove('d-none');
            setTimeout(() => {
                document.getElementById('registerModal').querySelector('.btn-close').click();
                showLogin();
            }, 1500);
        } else {
            messageEl.className = 'alert alert-danger';
            messageEl.textContent = 'Ошибка регистрации. Возможно, пользователь уже существует.';
            messageEl.classList.remove('d-none');
        }
    }

    function createAlbum() {
        {% if user.is_authenticated %}
        window.location.href = '/albums/create/';
        {% else %}
        showLogin();
        {% endif %}
    }

    function viewAlbum(albumId) {
        window.location.href = `/albums/${albumId}/`;
    }
</script>
